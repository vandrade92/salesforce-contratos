        if (category == 'parecer') {
            return 'Elaboracao_de_Parecer';
        }
        if (category == 'diagnostico') {
            return 'Diagnostico_de_Contrato';
        }

        return null;
    }

    private static void applyRecordTypeByContractType(List<Contrato__c> contratos) {
        if (contratos == null || contratos.isEmpty()) {
            return;
        }

        Map<String, List<Contrato__c>> contratosByRecordType = new Map<String, List<Contrato__c>>();
        for (Contrato__c contrato : contratos) {
            String category = detectCategory(contrato == null ? null : contrato.Tipo_Contrato__c);
            String recordTypeDeveloperName = mapCategoryToRecordTypeDeveloperName(category);
            if (String.isBlank(recordTypeDeveloperName)) {
                continue;
            }

            if (!contratosByRecordType.containsKey(recordTypeDeveloperName)) {
                contratosByRecordType.put(recordTypeDeveloperName, new List<Contrato__c>());
            }
            contratosByRecordType.get(recordTypeDeveloperName).add(contrato);
        }

        if (contratosByRecordType.isEmpty()) {
            return;
        }

        Map<String, Id> recordTypeIdByDeveloperName = new Map<String, Id>();
        for (RecordType rt : [
            SELECT Id, DeveloperName
            FROM RecordType
            WHERE SObjectType = 'Contrato__c'
              AND IsActive = true
              AND DeveloperName IN :contratosByRecordType.keySet()
        ]) {
            recordTypeIdByDeveloperName.put(rt.DeveloperName, rt.Id);
        }

        for (String developerName : contratosByRecordType.keySet()) {
            Id recordTypeId = recordTypeIdByDeveloperName.get(developerName);
            if (recordTypeId == null) {
                continue;
            }

            for (Contrato__c contrato : contratosByRecordType.get(developerName)) {
                Id currentRecordTypeId = null;
                Map<String, Object> populatedFields = contrato.getPopulatedFieldsAsMap();
                if (populatedFields.containsKey('RecordTypeId')) {
                    currentRecordTypeId = (Id) populatedFields.get('RecordTypeId');
                }
                if (currentRecordTypeId != recordTypeId) {
                    contrato.put('RecordTypeId', recordTypeId);
                }
            }
        }
    }
    @TestVisible
    private static String detectCategory(String input) {
        if (!String.isBlank(input)) {
            String lowered = input.toLowerCase();
            if (lowered.contains('monitoramento')) {
                return 'monitoramento';
            }
            if (lowered.contains('parecer')) {
                return 'parecer';
            }
            if (lowered.contains('diagn')) {
                return 'diagnostico';
            }
            if (lowered.contains('judicial') || lowered.contains('assist') || lowered.contains('processo')) {
                return 'assistencia';
            }
        }

        String normalized = normalizeText(input);
        if (String.isBlank(normalized)) {
            return null;
        }

        if (normalized.contains('monitoramento')) {
            return 'monitoramento';
        }
        if (normalized.contains('parecer')) {
            return 'parecer';
        }
        if (normalized.contains('diagn')) {
            return 'diagnostico';
        }
        if (normalized.contains('judicial') || normalized.contains('assist') || normalized.contains('processo')) {
            return 'assistencia';
        }

        return null;
    }

