    @TestVisible
    private static String detectServiceCategory(String serviceName) {
        if (String.isBlank(serviceName)) {
            return null;
        }

        String normalized = normalizeText(serviceName);
        if (String.isBlank(normalized)) {
            return null;
        }

        String explicitCategory = getCategoryByNormalizedService().get(normalized);
        if (!String.isBlank(explicitCategory)) {
            return explicitCategory;
        }

        if (normalized.contains('monitoramento') && normalized.contains('remoto')) {
            return 'monitoramento';
        }
        if ((normalized.contains('assist') || normalized.contains('acao')) && normalized.contains('judicial')) {
            return 'assistencia';
        }
        if (normalized.contains('parecer')) {
            return 'parecer';
        }
        if (normalized.contains('diagn')) {
            return 'diagnostico';
        }

        return null;
    }

    private static Map<String, String> getCategoryByNormalizedService() {
        if (categoryByNormalizedService != null) {
            return categoryByNormalizedService;
        }

        categoryByNormalizedService = new Map<String, String>();
        categoryByNormalizedService.put(normalizeText('Monitoramento Remoto'), 'monitoramento');
        categoryByNormalizedService.put(normalizeText('Assist. Tec. em Processo Judicial'), 'assistencia');
        categoryByNormalizedService.put(normalizeText('Assist. Téc. em Processo Judicial'), 'assistencia');
        categoryByNormalizedService.put(normalizeText('Assistencia Tecnica em Processo Judicial'), 'assistencia');
        categoryByNormalizedService.put(normalizeText('Acao Judicial'), 'assistencia');
        categoryByNormalizedService.put(normalizeText('Ação Judicial'), 'assistencia');
        categoryByNormalizedService.put(normalizeText('Elaboracao de Parecer Tecnico'), 'parecer');
        categoryByNormalizedService.put(normalizeText('Elaboração de Parecer Técnico'), 'parecer');
        categoryByNormalizedService.put(normalizeText('Diagnostico de Contrato'), 'diagnostico');
        categoryByNormalizedService.put(normalizeText('Diagnóstico de Contrato'), 'diagnostico');
        categoryByNormalizedService.put(normalizeText('Diagnostico + Pleito'), 'diagnostico');
        categoryByNormalizedService.put(normalizeText('Diagnóstico + Pleito'), 'diagnostico');

        return categoryByNormalizedService;
    }

    @TestVisible
    private static String mapServiceToContractType(String serviceName) {
        if (String.isBlank(serviceName)) {
            return null;
        }

        String category = detectServiceCategory(serviceName);
        if (String.isBlank(category)) {
            return null;
        }

        return getTipoContratoByCategory().get(category);
    }

    private static Map<String, String> getTipoContratoByCategory() {
        if (tipoContratoByCategory != null) {
            return tipoContratoByCategory;
        }

        tipoContratoByCategory = new Map<String, String>();
        for (Schema.PicklistEntry entry : Contrato__c.Tipo_Contrato__c.getDescribe().getPicklistValues()) {
            if (!entry.isActive()) {
                continue;
            }

            String category = detectCategory(entry.getValue());
            if (!String.isBlank(category) && !tipoContratoByCategory.containsKey(category)) {
                tipoContratoByCategory.put(category, entry.getValue());
            }
        }

        return tipoContratoByCategory;
    }

