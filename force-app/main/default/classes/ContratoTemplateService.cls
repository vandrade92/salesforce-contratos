public without sharing class ContratoTemplateService {
    @TestVisible
    private static Map<String, String> tipoContratoByCategory;
    @TestVisible
    private static Map<String, String> categoryByNormalizedService;

    private static final Pattern PLACEHOLDER_PATTERN = Pattern.compile('X{3,}');
    private static final String ERROR_SERVICE_NOT_MAPPED =
        'Servico da oportunidade nao mapeado para contrato. Ajuste Opportunity.Servico__c ou preencha Tipo_Contrato__c manualmente.';
    private static final String ERROR_TEMPLATE_NOT_FOUND =
        'Nao existe Contrato_Padrao__c ativo para o Tipo_Contrato__c informado.';
    private static final String ERROR_MISSING_OPPORTUNITY_DATA_PREFIX =
        'Preencha os campos obrigatorios na Oportunidade antes de gerar o contrato: ';

    public static void defaultContractTypeAndTemplate(List<Contrato__c> contratos) {
        defaultContractTypeAndTemplate(contratos, false);
    }

    public static void defaultContractTypeAndTemplate(List<Contrato__c> contratos, Boolean enforceValidations) {
        if (contratos == null || contratos.isEmpty()) {
            return;
        }

        Set<Id> opportunityIds = new Set<Id>();
        for (Contrato__c contrato : contratos) {
            if (contrato.Oportunidade__c != null) {
                opportunityIds.add(contrato.Oportunidade__c);
            }
        }

        Map<Id, Opportunity> oppById = new Map<Id, Opportunity>();
        if (!opportunityIds.isEmpty()) {
            oppById = new Map<Id, Opportunity>([
                SELECT Id,
                       Name,
                       Servico__c,
                       AccountId,
                       Contato_Contrato__c,
                       Proposta__c,
                       Data_Envio_Proposta__c,
                       Amount,
                       Quantidade_Visitas__c,
                       Valor_Mensal_Monitoramento__c,
                       CloseDate,
                       Dona_da_Obra__c,
                       Municipio_Obra__c,
                       Prazo_Parecer_Dias__c,
                       Prazo_Parecer_Dias_Extenso__c,
                       Prazo_Minimo_Pleito_Dias__c,
                       Prazo_Pagamento_Dias__c,
                       Valor_Unico_Pleito__c,
                       Taxa_Sucesso_Pleito__c
                FROM Opportunity
                WHERE Id IN :opportunityIds
            ]);
        }

        Set<String> neededTemplateNames = new Set<String>();
        for (Contrato__c contrato : contratos) {
            Opportunity opp = contrato.Oportunidade__c == null
                ? null
                : oppById.get(contrato.Oportunidade__c);

            if (String.isBlank(contrato.Tipo_Contrato__c) && contrato.Oportunidade__c != null) {
                if (opp != null) {
                    contrato.Tipo_Contrato__c = mapServiceToContractType(opp.Servico__c);
                }
            }

            if (enforceValidations == true) {
                validateBeforeContractInitialization(contrato, opp);
            }

            if (contrato.Contrato_Padrao__c == null && !String.isBlank(contrato.Tipo_Contrato__c)) {
                neededTemplateNames.add(contrato.Tipo_Contrato__c);
            }
        }

        applyRecordTypeByContractType(contratos);

        if (neededTemplateNames.isEmpty()) {
            return;
        }

        Map<String, Contrato_Padrao__c> templateByName = new Map<String, Contrato_Padrao__c>();
        for (Contrato_Padrao__c template : [
            SELECT Id, Name, Ativo__c
            FROM Contrato_Padrao__c
            WHERE Ativo__c = true AND Name IN :neededTemplateNames
        ]) {
            if (!templateByName.containsKey(template.Name)) {
                templateByName.put(template.Name, template);
            }
        }

        for (Contrato__c contrato : contratos) {
            if (contrato.Contrato_Padrao__c == null && !String.isBlank(contrato.Tipo_Contrato__c)) {
                Contrato_Padrao__c template = templateByName.get(contrato.Tipo_Contrato__c);
                if (template != null) {
                    contrato.Contrato_Padrao__c = template.Id;
                } else if (enforceValidations == true) {
                    contrato.Contrato_Padrao__c.addError(ERROR_TEMPLATE_NOT_FOUND);
                }
            }
        }
    }

    public static void initializeContracts(Set<Id> contratoIds) {
        initializeContractsInternal(contratoIds, false);
    }

    public static void reloadClauses(Set<Id> contratoIds) {
        initializeContractsInternal(contratoIds, true);
    }

    private static void initializeContractsInternal(Set<Id> contratoIds, Boolean forceReload) {
        if (contratoIds == null || contratoIds.isEmpty()) {
            return;
        }

        List<Contrato__c> contratos = [
            SELECT Id,
                   Name,
                   RecordTypeId,
                   Oportunidade__c,
                   Contrato_Padrao__c,
                   Tipo_Contrato__c,
                   Inicializado__c,
                   Versao_Documento__c,
                   Contratante_Razao_Social__c,
                   Contratante_CNPJ__c,
                   Contratante_Endereco_Completo__c,
                   Contratante_Cidade__c,
                   Contratante_Estado__c,
                   Contratante_CEP__c,
                   Contratante_Email__c,
                   Contratante_Telefone__c,
                   Representante_Legal_Nome__c,
                   Representante_Legal_Cargo__c,
                   Numero_Proposta__c,
                   Data_Base__c,
                   Objeto_Servicos__c,
                   Valor_Total_Servico__c,
                   Quantidade_Visitas__c,
                   Valor_Mensal_Monitoramento__c,
                   Dona_da_Obra__c,
                   Municipio_Obra__c,
                   Prazo_Parecer_Dias__c,
                   Prazo_Parecer_Dias_Extenso__c,
                   Prazo_Minimo_Pleito_Dias__c,
                   Prazo_Pagamento_Dias__c,
                   Valor_Unico_Pleito__c,
                   Taxa_Sucesso_Pleito__c,
                   Data_Assinatura_Contrato__c,
                   Local_Obra__c
            FROM Contrato__c
            WHERE Id IN :contratoIds
        ];

        if (contratos.isEmpty()) {
            return;
        }

        defaultContractTypeAndTemplate(contratos);

        Set<Id> opportunityIds = new Set<Id>();
        for (Contrato__c contrato : contratos) {
            if (contrato.Oportunidade__c != null) {
                opportunityIds.add(contrato.Oportunidade__c);
            }
        }

        Map<Id, Opportunity> oppById = new Map<Id, Opportunity>();
        if (!opportunityIds.isEmpty()) {
            oppById = new Map<Id, Opportunity>([
                SELECT Id,
                       Name,
                       Servico__c,
                       AccountId,
                       Contato_Contrato__c,
                       Proposta__c,
                       Data_Envio_Proposta__c,
                       Amount,
                       Quantidade_Visitas__c,
                       Valor_Mensal_Monitoramento__c,
                       CloseDate,
                       Dona_da_Obra__c,
                       Municipio_Obra__c,
                       Prazo_Parecer_Dias__c,
                       Prazo_Parecer_Dias_Extenso__c,
                       Prazo_Minimo_Pleito_Dias__c,
                       Prazo_Pagamento_Dias__c,
                       Valor_Unico_Pleito__c,
                       Taxa_Sucesso_Pleito__c
                FROM Opportunity
                WHERE Id IN :opportunityIds
            ]);
        }

        Set<Id> accountIds = new Set<Id>();
        Set<Id> contactIds = new Set<Id>();
        for (Opportunity opp : oppById.values()) {
            if (opp.AccountId != null) {
                accountIds.add(opp.AccountId);
            }
            if (opp.Contato_Contrato__c != null) {
                contactIds.add(opp.Contato_Contrato__c);
            }
        }

        Map<Id, Account> accountById = new Map<Id, Account>();
        if (!accountIds.isEmpty()) {
            accountById = new Map<Id, Account>([
                SELECT Id,
                       Name,
                       CNPJ__c,
                       BillingStreet,
                       BillingCity,
                       BillingState,
                       BillingPostalCode,
                       Phone
                FROM Account
                WHERE Id IN :accountIds
            ]);
        }

        Map<Id, Contact> contactById = new Map<Id, Contact>();
        if (!contactIds.isEmpty()) {
            contactById = new Map<Id, Contact>([
                SELECT Id,
                       Name,
                       Title,
                       Email,
                       Phone,
                       MobilePhone
                FROM Contact
                WHERE Id IN :contactIds
            ]);
        }

        List<Contrato__c> contratosToUpdate = new List<Contrato__c>();
        for (Contrato__c contrato : contratos) {
            Opportunity opp = oppById.get(contrato.Oportunidade__c);
            if (opp == null) {
                continue;
            }

            Account acc = accountById.get(opp.AccountId);
            Contact contato = contactById.get(opp.Contato_Contrato__c);

            if (acc != null) {
                contrato.Contratante_Razao_Social__c = acc.Name;
                if (acc.CNPJ__c != null) {
                    contrato.Contratante_CNPJ__c = String.valueOf(acc.CNPJ__c);
                }
                contrato.Contratante_Endereco_Completo__c = buildAddress(acc);
                contrato.Contratante_Cidade__c = acc.BillingCity;
                contrato.Contratante_Estado__c = acc.BillingState;
                contrato.Contratante_CEP__c = acc.BillingPostalCode;
                contrato.Contratante_Telefone__c = acc.Phone;
            }

            if (contato != null) {
                contrato.Representante_Legal_Nome__c = contato.Name;
                contrato.Representante_Legal_Cargo__c = contato.Title;
                contrato.Contratante_Email__c = contato.Email;
                contrato.Contratante_Telefone__c = String.isBlank(contato.Phone) ? contato.MobilePhone : contato.Phone;
            }

            contrato.Numero_Proposta__c = opp.Proposta__c == null ? contrato.Numero_Proposta__c : String.valueOf(opp.Proposta__c);
            contrato.Data_Base__c = opp.Data_Envio_Proposta__c;

            if (String.isBlank(contrato.Objeto_Servicos__c) && !String.isBlank(opp.Servico__c)) {
                contrato.Objeto_Servicos__c = 'Servico contratado: ' + opp.Servico__c;
            }

            if (contrato.Valor_Total_Servico__c == null) {
                if (opp.Amount != null) {
                    contrato.Valor_Total_Servico__c = opp.Amount;
                } else if (opp.Proposta__c != null) {
                    contrato.Valor_Total_Servico__c = opp.Proposta__c;
                }
            }

            copyDynamicDataSnapshot(contrato, opp, forceReload);

            if (!contrato.Inicializado__c || forceReload) {
                contrato.Inicializado__c = true;
            }

            contratosToUpdate.add(contrato);
        }

        if (!contratosToUpdate.isEmpty()) {
            update contratosToUpdate;
        }

        Map<Id, List<Clausula_Padrao__c>> clausesByTemplateId = new Map<Id, List<Clausula_Padrao__c>>();
        Set<Id> templateIds = new Set<Id>();
        for (Contrato__c contrato : contratos) {
            if (contrato.Contrato_Padrao__c != null) {
                templateIds.add(contrato.Contrato_Padrao__c);
            }
        }

        if (templateIds.isEmpty()) {
            return;
        }

        for (Clausula_Padrao__c clause : [
            SELECT Id,
                   Contrato_Padrao__c,
                   Secao__c,
                   Titulo__c,
                   Ordem__c,
                   Texto_Base__c,
                   Ativa__c
            FROM Clausula_Padrao__c
            WHERE Contrato_Padrao__c IN :templateIds AND Ativa__c = true
            ORDER BY Ordem__c ASC, CreatedDate ASC
        ]) {
            List<Clausula_Padrao__c> bucket = clausesByTemplateId.get(clause.Contrato_Padrao__c);
            if (bucket == null) {
                bucket = new List<Clausula_Padrao__c>();
                clausesByTemplateId.put(clause.Contrato_Padrao__c, bucket);
            }
            bucket.add(clause);
        }

        Map<Id, Integer> existingCountByContratoId = new Map<Id, Integer>();
        if (!forceReload) {
            for (AggregateResult ar : [
                SELECT Contrato__c contratoId, COUNT(Id) total
                FROM Clausula__c
                WHERE Contrato__c IN :contratoIds
                GROUP BY Contrato__c
            ]) {
                existingCountByContratoId.put((Id) ar.get('contratoId'), (Integer) ar.get('total'));
            }
        } else {
            List<Clausula__c> clausesToDelete = [
                SELECT Id
                FROM Clausula__c
                WHERE Contrato__c IN :contratoIds
            ];
            if (!clausesToDelete.isEmpty()) {
                delete clausesToDelete;
            }
        }

        List<Clausula__c> clausesToInsert = new List<Clausula__c>();
        for (Contrato__c contrato : contratos) {
            if (contrato.Contrato_Padrao__c == null) {
                continue;
            }

            Integer existingCount = existingCountByContratoId.get(contrato.Id);
            Boolean shouldCreate = forceReload || existingCount == null || existingCount == 0;
            if (!shouldCreate) {
                continue;
            }

            List<Clausula_Padrao__c> modelClauses = clausesByTemplateId.get(contrato.Contrato_Padrao__c);
            if (modelClauses == null || modelClauses.isEmpty()) {
                continue;
            }

            Opportunity opp = oppById.get(contrato.Oportunidade__c);
            for (Clausula_Padrao__c modelClause : modelClauses) {
                Clausula__c newClause = new Clausula__c();
                newClause.Contrato__c = contrato.Id;
                newClause.Origem_Clausula_Padrao__c = modelClause.Id;
                newClause.Secao__c = modelClause.Secao__c;
                newClause.Titulo__c = modelClause.Titulo__c;
                newClause.Ordem__c = modelClause.Ordem__c;
                newClause.Texto__c = applyDynamicPlaceholders(modelClause.Texto_Base__c, modelClause.Titulo__c, contrato, opp);
                newClause.Editada__c = false;
                newClause.Ativa__c = true;
                clausesToInsert.add(newClause);
            }
        }

        if (!clausesToInsert.isEmpty()) {
            insert clausesToInsert;
        }
    }

    @TestVisible
    private static String applyDynamicPlaceholders(
        String baseText,
        String clauseTitle,
        Contrato__c contrato,
        Opportunity opp
    ) {
        if (String.isBlank(baseText) || baseText.indexOf('XX') < 0) {
            return baseText;
        }

        String output = applyPrazoPagamentoPlaceholder(baseText, clauseTitle, contrato, opp);
        if (output.indexOf('XX') < 0) {
            return output;
        }

        String category = detectCategory(contrato == null ? null : contrato.Tipo_Contrato__c);
        if (String.isBlank(category)) {
            category = detectCategory(opp == null ? null : opp.Servico__c);
        }
        if (String.isBlank(category)) {
            return output;
        }

        String clauseKey = detectClauseKey(clauseTitle);
        if (String.isBlank(clauseKey)) {
            return output;
        }

        List<String> replacements = buildClauseReplacements(category, clauseKey, contrato, opp);
        if (replacements.isEmpty()) {
            return output;
        }

        return replaceSequentialPlaceholders(output, replacements);
    }

    private static String applyPrazoPagamentoPlaceholder(
        String input,
        String clauseTitle,
        Contrato__c contrato,
        Opportunity opp
    ) {
        if (String.isBlank(input) || input.indexOf('XX') < 0) {
            return input;
        }

        String clauseKey = detectClauseKey(clauseTitle);
        if (clauseKey != 'remuneracao') {
            return input;
        }

        String prazoPagamentoDias = resolvePrazoPagamentoDias(contrato, opp);
        if (String.isBlank(prazoPagamentoDias)) {
            return input;
        }

        return input.replaceAll('\\bXX\\b(?=\\s+dias?)', prazoPagamentoDias);
    }

    private static String resolvePrazoPagamentoDias(Contrato__c contrato, Opportunity opp) {
        if (contrato != null && contrato.Prazo_Pagamento_Dias__c != null) {
            return formatWholeNumber(contrato.Prazo_Pagamento_Dias__c);
        }

        if (opp != null && opp.Prazo_Pagamento_Dias__c != null) {
            return formatWholeNumber(opp.Prazo_Pagamento_Dias__c);
        }

        return null;
    }

    private static void copyDynamicDataSnapshot(Contrato__c contrato, Opportunity opp, Boolean forceReload) {
        if (contrato == null || opp == null) {
            return;
        }

        if (forceReload || String.isBlank(contrato.Dona_da_Obra__c)) {
            contrato.Dona_da_Obra__c = opp.Dona_da_Obra__c;
        }

        if (forceReload || String.isBlank(contrato.Municipio_Obra__c)) {
            contrato.Municipio_Obra__c = opp.Municipio_Obra__c;
        }

        if ((forceReload || String.isBlank(contrato.Local_Obra__c)) && !String.isBlank(opp.Municipio_Obra__c)) {
            contrato.Local_Obra__c = opp.Municipio_Obra__c;
        }

        if (forceReload || contrato.Prazo_Parecer_Dias__c == null) {
            contrato.Prazo_Parecer_Dias__c = opp.Prazo_Parecer_Dias__c;
        }

        if (forceReload || String.isBlank(contrato.Prazo_Parecer_Dias_Extenso__c)) {
            contrato.Prazo_Parecer_Dias_Extenso__c = opp.Prazo_Parecer_Dias_Extenso__c;
        }

        if (forceReload || contrato.Prazo_Minimo_Pleito_Dias__c == null) {
            contrato.Prazo_Minimo_Pleito_Dias__c = opp.Prazo_Minimo_Pleito_Dias__c;
        }

        if (forceReload || contrato.Prazo_Pagamento_Dias__c == null) {
            contrato.Prazo_Pagamento_Dias__c = opp.Prazo_Pagamento_Dias__c;
        }

        if (forceReload || contrato.Quantidade_Visitas__c == null) {
            contrato.Quantidade_Visitas__c = opp.Quantidade_Visitas__c;
        }

        if (forceReload || contrato.Valor_Mensal_Monitoramento__c == null) {
            contrato.Valor_Mensal_Monitoramento__c = opp.Valor_Mensal_Monitoramento__c;
        }

        if (forceReload || contrato.Valor_Unico_Pleito__c == null) {
            contrato.Valor_Unico_Pleito__c = opp.Valor_Unico_Pleito__c;
        }

        if (forceReload || contrato.Taxa_Sucesso_Pleito__c == null) {
            contrato.Taxa_Sucesso_Pleito__c = opp.Taxa_Sucesso_Pleito__c;
        }

    }
    private static List<String> buildClauseReplacements(
        String category,
        String clauseKey,
        Contrato__c contrato,
        Opportunity opp
    ) {
        List<String> values = new List<String>();

        if (category == 'parecer') {
            if (clauseKey == 'objeto') {
                values.add(firstNonBlank(contrato.Contratante_Razao_Social__c));
                values.add(resolveDonaObra(contrato));
                values.add(resolveMunicipioObra(contrato));
            } else if (clauseKey == 'prazo') {
                values.add(formatWholeNumber(contrato.Prazo_Parecer_Dias__c));
                values.add(resolvePrazoParecerExtenso(contrato));
            } else if (clauseKey == 'disposicoes') {
                values.add(resolveCidadeDestinoAssinatura(contrato));
                values.add(formatContractDate(contrato.Data_Assinatura_Contrato__c));
            }
        } else if (category == 'monitoramento') {
            if (clauseKey == 'objeto') {
                values.add(resolveDonaObra(contrato));
            } else if (clauseKey == 'remuneracao') {
                values.add(formatWholeNumber(contrato.Prazo_Minimo_Pleito_Dias__c));
                values.add(formatCurrency(contrato.Valor_Unico_Pleito__c));
                values.add(formatPercent(contrato.Taxa_Sucesso_Pleito__c));
            } else if (clauseKey == 'disposicoes') {
                values.add(formatContractDate(contrato.Data_Assinatura_Contrato__c));
            }
        } else if (category == 'assistencia') {
            if (clauseKey == 'disposicoes') {
                values.add(formatContractDate(contrato.Data_Assinatura_Contrato__c));
            }
        }

        return values;
    }

    private static String resolveDonaObra(Contrato__c contrato) {
        return firstNonBlank(
            contrato.Dona_da_Obra__c,
            contrato.Contratante_Razao_Social__c
        );
    }

    private static String resolveMunicipioObra(Contrato__c contrato) {
        return firstNonBlank(
            contrato.Municipio_Obra__c,
            contrato.Local_Obra__c,
            contrato.Contratante_Cidade__c
        );
    }

    private static String resolvePrazoParecerExtenso(Contrato__c contrato) {
        String extenso = firstNonBlank(contrato.Prazo_Parecer_Dias_Extenso__c);
        if (!String.isBlank(extenso)) {
            return extenso;
        }

        return formatWholeNumber(contrato.Prazo_Parecer_Dias__c);
    }

    private static String resolveCidadeDestinoAssinatura(Contrato__c contrato) {
        return firstNonBlank(
            contrato.Contratante_Cidade__c,
            contrato.Municipio_Obra__c,
            'Nova Lima'
        );
    }

    private static String replaceSequentialPlaceholders(String baseText, List<String> replacementValues) {
        if (String.isBlank(baseText) || replacementValues == null || replacementValues.isEmpty()) {
            return baseText;
        }

        Matcher matcher = PLACEHOLDER_PATTERN.matcher(baseText);
        if (!matcher.find()) {
            return baseText;
        }

        matcher = PLACEHOLDER_PATTERN.matcher(baseText);
        String output = '';
        Integer replacementIndex = 0;
        Integer lastEnd = 0;

        while (matcher.find()) {
            output += baseText.substring(lastEnd, matcher.start());

            String replacement = replacementIndex < replacementValues.size()
                ? replacementValues[replacementIndex]
                : null;

            if (String.isBlank(replacement)) {
                output += matcher.group();
            } else {
                output += replacement;
            }

            lastEnd = matcher.end();
            replacementIndex++;
        }

        output += baseText.substring(lastEnd);
        return output;
    }

    private static String detectClauseKey(String clauseTitle) {
        String normalized = normalizeText(clauseTitle);
        if (String.isBlank(normalized)) {
            return null;
        }

        if (normalized.contains('objeto')) {
            return 'objeto';
        }
        if (normalized.contains('remuner') || normalized.contains('pagamento')) {
            return 'remuneracao';
        }
        if (normalized.contains('prazo')) {
            return 'prazo';
        }
        if (normalized.contains('dispos')) {
            return 'disposicoes';
        }

        return null;
    }

    private static String formatContractDate(Date value) {
        Date toFormat = value == null ? Date.today() : value;
        return Datetime.newInstance(toFormat, Time.newInstance(0, 0, 0, 0)).format('dd/MM/yyyy');
    }

    private static String formatWholeNumber(Decimal value) {
        if (value == null) {
            return null;
        }

        Decimal scaled = value.setScale(0);
        return String.valueOf(scaled);
    }

    private static String formatCurrency(Decimal value) {
        if (value == null) {
            return null;
        }

        return value.setScale(2).format();
    }

    private static String formatPercent(Decimal value) {
        if (value == null) {
            return null;
        }

        return value.setScale(2).format() + '%';
    }

    private static String firstNonBlank(String one) {
        if (!String.isBlank(one)) {
            return one;
        }

        return null;
    }

    private static String firstNonBlank(String one, String two) {
        if (!String.isBlank(one)) {
            return one;
        }
        if (!String.isBlank(two)) {
            return two;
        }

        return null;
    }

    private static String firstNonBlank(String one, String two, String three) {
        if (!String.isBlank(one)) {
            return one;
        }
        if (!String.isBlank(two)) {
            return two;
        }
        if (!String.isBlank(three)) {
            return three;
        }

        return null;
    }

    private static void validateBeforeContractInitialization(Contrato__c contrato, Opportunity opp) {
        if (contrato == null || opp == null) {
            return;
        }

        String categoryFromTipo = detectCategory(contrato.Tipo_Contrato__c);
        String categoryFromService = detectServiceCategory(opp.Servico__c);

        if (String.isBlank(categoryFromTipo) && String.isBlank(categoryFromService)) {
            contrato.Tipo_Contrato__c.addError(ERROR_SERVICE_NOT_MAPPED);
            return;
        }

        String effectiveCategory = String.isBlank(categoryFromTipo)
            ? categoryFromService
            : categoryFromTipo;

        List<String> missingFields = collectRequiredOpportunityFields(opp, effectiveCategory);
        if (!missingFields.isEmpty()) {
            contrato.addError(ERROR_MISSING_OPPORTUNITY_DATA_PREFIX + String.join(missingFields, ', '));
        }
    }

    private static List<String> collectRequiredOpportunityFields(Opportunity opp, String category) {
        List<String> missingFields = new List<String>();
        if (opp == null) {
            return missingFields;
        }

        if (opp.AccountId == null) {
