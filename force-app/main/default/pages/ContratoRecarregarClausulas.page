<apex:page controller="ContratoReloadClausesController" showHeader="false" sidebar="false" lightningStylesheets="true">
    <apex:form >
        <apex:pageMessages />
        <apex:pageBlock title="Recarregar Clausulas do Padrao">
            <apex:pageBlockSection columns="1">
                <apex:outputText value="Esta acao substituira todas as clausulas atuais do contrato pelas clausulas do modelo padrao selecionado."/>
                <apex:outputText value="Use esta acao somente quando desejar reiniciar a minuta com base no padrao."/>
            </apex:pageBlockSection>
            <apex:pageBlockButtons >
                <apex:commandButton value="Confirmar recarga" action="{!confirmReload}"/>
                <apex:commandButton value="Cancelar" action="{!cancel}" immediate="true"/>
            </apex:pageBlockButtons>
        </apex:pageBlock>
    </apex:form>
</apex:page>

